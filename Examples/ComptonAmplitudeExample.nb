        RowBox[{"h3", ",", "h4"}], "]"}], "//", "ToExp"}], "//", 
      RowBox[{"PureGaugeTransformation", "[", "3", "]"}]}], "//", 
     "SHToMandelstam"}], "//", "Simplify"}], "//", 
   RowBox[{"ReplaceRepeated", "[", 
    RowBox[{
     RowBox[{
      TemplateBox[{"a_", "1", "b_"},
       "ABScalar",
       DisplayFunction->(
        RowBox[{"\[LeftAngleBracket]", #, "\[RightBracketingBar]", #2, 
          "\[LeftBracketingBar]", #3, "]"}]& ),
       InterpretationFunction->(
        RowBox[{"SHAB", "[", #, ",", #2, ",", #3, "]"}]& )], "+", 
      TemplateBox[{"a_", "2", "b_"},
       "ABScalar",
       DisplayFunction->(
        RowBox[{"\[LeftAngleBracket]", #, "\[RightBracketingBar]", #2, 
          "\[LeftBracketingBar]", #3, "]"}]& ),
       InterpretationFunction->(
        RowBox[{"SHAB", "[", #, ",", #2, ",", #3, "]"}]& )]}], ":>", " ", 
     RowBox[{
      RowBox[{"-", 
       TemplateBox[{"a", "3", "b"},
        "ABScalar",
        DisplayFunction->(
         RowBox[{"\[LeftAngleBracket]", #, "\[RightBracketingBar]", #2, 
           "\[LeftBracketingBar]", #3, "]"}]& ),
        InterpretationFunction->(
         RowBox[{"SHAB", "[", #, ",", #2, ",", #3, "]"}]& )]}], "-", 
      TemplateBox[{"a", "4", "b"},
       "ABScalar",
       DisplayFunction->(
        RowBox[{"\[LeftAngleBracket]", #, "\[RightBracketingBar]", #2, 
          "\[LeftBracketingBar]", #3, "]"}]& ),
       InterpretationFunction->(
        RowBox[{"SHAB", "[", #, ",", #2, ",", #3, "]"}]& )]}]}], 
    "]"}]}]}]], "Input",
 InitializationCell->True,
