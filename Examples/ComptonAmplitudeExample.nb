Cell[BoxData[
 RowBox[{"Clear", "[", "TChannel", "]"}]], "Input",
 CellChangeTimes->{{3.9913754818992996`*^9, 3.9913754855772457`*^9}},
 CellLabel->
  "In[206]:=",ExpressionUUID->"e2bbf764-0538-5740-8958-668a63504a95"],

Cell[BoxData[
 RowBox[{
  RowBox[{"TChannel", "[", 
   RowBox[{"S_", ",", "h3_", ",", "h4_"}], "]"}], ":=", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"LeftStrippedVertex", "[", 
         RowBox[{"S", ",", "h3"}], "]"}], " ", "*", " ", 
        RowBox[{"UGPropagator", "[", 
         RowBox[{"S", ",", 
          RowBox[{"k1", "+", "k4"}], ",", 
          RowBox[{"m", "[", "1", "]"}]}], "]"}], "*", " ", 
        RowBox[{"RightStrippedVertex", "[", 
         RowBox[{"S", ",", "h4"}], "]"}]}], "//", "SimplifyPolynomial"}], "//", 
      RowBox[{
       RowBox[{"Limit", "[", 
        RowBox[{"#", ",", 
         RowBox[{"\[CurlyEpsilon]", "->", " ", "0"}]}], "]"}], "&"}]}], "//", 
     RowBox[{"ReplaceRepeated", "[", 
      RowBox[{
       TemplateBox[{"2", 
         TemplateBox[{
           StyleBox["J", FontColor -> RGBColor[1, 0, 0]], 
           StyleBox["2", FontColor -> RGBColor[1, 0, 0]]}, "littlegroupindex",
           DisplayFunction -> (RowBox[{#, "\[NegativeVeryThinSpace]", #2}]& ),
           InterpretationFunction -> (
           RowBox[{"MsIndex", "[", #, ",", #2, "]"}]& )], "1", "2", 
         TemplateBox[{
           StyleBox["J", FontColor -> RGBColor[1, 0, 0]], 
           StyleBox["2", FontColor -> RGBColor[1, 0, 0]]}, "littlegroupindex",
           DisplayFunction -> (RowBox[{#, "\[NegativeVeryThinSpace]", #2}]& ),
           InterpretationFunction -> (
           RowBox[{"MsIndex", "[", #, ",", #2, "]"}]& )]},
        "ABScalar",
        DisplayFunction->(RowBox[{"\[LeftAngleBracket]", 
           SuperscriptBox[#, #2], "\[RightBracketingBar]", #3, 
           "\[LeftBracketingBar]", 
           SuperscriptBox[#4, #5], "]"}]& ),
        InterpretationFunction->(
         RowBox[{"SHAB", "[", #, "[", #2, "]", ",", #3, ",", #4, "[", #5, "]",
            "]"}]& )], ":>", " ", 
       RowBox[{
        RowBox[{"StandardizeExpression", "[", "]"}], "[", 
        TemplateBox[{"2", 
          TemplateBox[{
            StyleBox["J", FontColor -> RGBColor[1, 0, 0]], 
            StyleBox["2", FontColor -> RGBColor[1, 0, 0]]}, 
           "littlegroupindex", 
           DisplayFunction -> (RowBox[{#, "\[NegativeVeryThinSpace]", #2}]& ),
            InterpretationFunction -> (
            RowBox[{"MsIndex", "[", #, ",", #2, "]"}]& )], "1", "2", 
          TemplateBox[{
            StyleBox["J", FontColor -> RGBColor[1, 0, 0]], 
            StyleBox["2", FontColor -> RGBColor[1, 0, 0]]}, 
           "littlegroupindex", 
           DisplayFunction -> (RowBox[{#, "\[NegativeVeryThinSpace]", #2}]& ),
            InterpretationFunction -> (
            RowBox[{"MsIndex", "[", #, ",", #2, "]"}]& )]},
         "ABScalar",
         DisplayFunction->(RowBox[{"\[LeftAngleBracket]", 
            SuperscriptBox[#, #2], "\[RightBracketingBar]", #3, 
            "\[LeftBracketingBar]", 
            SuperscriptBox[#4, #5], "]"}]& ),
         InterpretationFunction->(
          RowBox[{"SHAB", "[", #, "[", #2, "]", ",", #3, ",", #4, "[", #5, 
            "]", "]"}]& )], "]"}]}], "]"}]}], "//", "PutOnShell"}], "//", 
   "Expand"}]}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.9913754729920006`*^9, 3.991375491373396*^9}, {
  3.991375544296299*^9, 3.9913755776924553`*^9}},
 CellLabel->
  "In[216]:=",ExpressionUUID->"bd10c0fe-6da7-624f-8b44-f5accdbd0394"],

Cell[TextData[{
 StyleBox["Note: ",
  FontColor->RGBColor[0.95, 0.43, 0.96]],
 StyleBox["Computing the exchange amplitude for spins ",
  FontColor->GrayLevel[0]],
 StyleBox[">= 2",
  FontWeight->"Plain",
  FontSlant->"Italic",
  FontColor->GrayLevel[0]],
 StyleBox[" takes a lot of time becuase the expression of propagator is huge \
and there are lots of contractions involved. \nWe give the analytical \
expression of the amplitude in terms of symbols as described in arxiv : 2506 \
: 12431. This can be checked with the bruteforce computation for any spin ",
  FontColor->GrayLevel[0]],
 StyleBox["S",
  FontWeight->"Plain",
  FontSlant->"Italic",
  FontColor->GrayLevel[0]],
 StyleBox[" ",
  FontSlant->"Italic",
  FontColor->GrayLevel[0]],
 StyleBox[".",
  FontColor->GrayLevel[0]]
}], "Input",
 CellChangeTimes->{{3.991375749411604*^9, 3.991375946847536*^9}, {
  3.9913761917702503`*^9, 3.9913761931699047`*^9}},
 FormatType->
  "TextForm",ExpressionUUID->"91f57dc5-9fc0-4b49-93f0-7a16e55d401d"],

Cell[TextData[{
 StyleBox["Basis of T Channel: ",
  FontColor->RGBColor[0.4, 0.6, 1]],
 StyleBox["The T channel amplitude can be written as a sum of two terms, each \
of which has its own indepdent contact term . The basis terms are symmetric \
homogenous polynomials of the scalars discussed above .",
  FontWeight->"Bold",
  FontColor->GrayLevel[0]]
}], "Input",
 CellChangeTimes->{{3.9913760531915836`*^9, 3.991376183295662*^9}, {
  3.991378939283188*^9, 3.9913789921625023`*^9}},
 FormatType->
  "TextForm",ExpressionUUID->"122a2a32-f97c-e442-8026-a71614942593"],

Cell[TextData[{
 StyleBox["We write the T channel as the product of the list of basis terms ",
  FontColor->GrayLevel[0]],
 StyleBox["TChannelBasis",
  FontWeight->"Plain",
  FontColor->RGBColor[0.4, 0.6, 1]],
 StyleBox[" and its coefficients ",
  FontColor->GrayLevel[0]],
 StyleBox["TChannelCoefficients. ",
  FontWeight->"Plain",
  FontColor->RGBColor[0.4, 0.6, 1]],
 StyleBox["The full",
  FontWeight->"Plain",
  FontColor->GrayLevel[0]],
 StyleBox[" TChannelAnalytic = TChannelBasis*TChannelCoefficients.",
  FontWeight->"Plain",
  FontColor->RGBColor[0.4, 0.6, 1]]
}], "Input",
 CellChangeTimes->{{3.9913789938313694`*^9, 3.9913790689616375`*^9}, {
  3.9913791066567287`*^9, 3.9913791557724743`*^9}},
 FormatType->
  "TextForm",ExpressionUUID->"45b8a488-cfd9-4049-a8b0-26afd38d6e95"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"TChannelBasis", "[", "S_", "]"}], ":=", 
   RowBox[{"\[ImaginaryI]", 
    SuperscriptBox[
     TemplateBox[{
       StyleBox["g", FontSlant -> Italic], "em"},
      "CouplingConstant",
      DisplayFunction->(SubscriptBox[#, #2]& ),
      InterpretationFunction->(RowBox[{"Coupling", "[", #, ",", #2, "]"}]& )],
      "2"], 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"\[CapitalOmega]0", "[", "S", "]"}], ",", 
      RowBox[{"\[CapitalUpsilon]t", "[", "S", "]"}]}], "}"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"TChannelCoefficients", "[", 
     RowBox[{"h3_", ",", "h4_"}], "]"}], ":=", 
    RowBox[{
     FractionBox[
      RowBox[{
       TemplateBox[{"3", "2", "h3"},
        "Xfactor",
        DisplayFunction->(SubsuperscriptBox["X", 
          RowBox[{#, #2}], #3]& ),
        InterpretationFunction->(
         RowBox[{"xfactor", "[", #, ",", #2, ",", #3, "]"}]& )], 
       TemplateBox[{"4", "1", "h4"},
        "Xfactor",
        DisplayFunction->(SubsuperscriptBox["X", 
          RowBox[{#, #2}], #3]& ),
        InterpretationFunction->(
         RowBox[{"xfactor", "[", #, ",", #2, ",", #3, "]"}]& )], " "}], 
      RowBox[{"2", 
       TemplateBox[{"1", "4"},
        "Mandelstam",
        DisplayFunction->(SubscriptBox["\[ScriptS]", 
          RowBox[{#, #2}]]& ),
        InterpretationFunction->(RowBox[{"sm", "[", #, ",", #2, "]"}]& )]}]], 
     RowBox[{"{", 
      RowBox[{"1", ",", 
       RowBox[{"\[Phi]14", " ", "\[Phi]23"}]}], "}"}]}]}], ";"}], 
  "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{
    "The", " ", "factor", " ", "of", " ", "2", " ", "in", " ", "the", " ", 
     "denominator", " ", "appears", " ", "due", " ", "to", " ", "mandelstam", 
     " ", "conversion", " ", 
     TemplateBox[{"i", "j"},
      "Mandelstam",
      DisplayFunction->(SubscriptBox["\[ScriptS]", 
        RowBox[{#, #2}]]& ),
      InterpretationFunction->(RowBox[{"sm", "[", #, ",", #2, "]"}]& )]}], "=", 
    RowBox[{
     FractionBox["1", "2"], 
     TemplateBox[{"i", "j", "i"},
      "ABScalar",
      DisplayFunction->(
       RowBox[{"\[LeftAngleBracket]", #, "\[RightBracketingBar]", #2, 
         "\[LeftBracketingBar]", #3, "]"}]& ),
      InterpretationFunction->(
       RowBox[{"SHAB", "[", #, ",", #2, ",", #3, "]"}]& )]}]}], "*)"}], 
  "\[IndentingNewLine]", "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"TChannelAnalytic", "[", 
   RowBox[{"S_", ",", "h3_", ",", "h4_"}], "]"}], ":=", 
  RowBox[{
   RowBox[{
    RowBox[{"TChannelBasis", "[", "S", "]"}], "*", 
    RowBox[{"TChannelCoefficients", "[", 
     RowBox[{"h3", ",", "h4"}], "]"}]}], "//", "Total"}]}]}], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.991378774743906*^9, 3.9913788675151367`*^9}, {
  3.991378946756468*^9, 3.991378953828493*^9}, {3.9913792173132896`*^9, 
  3.991379219979021*^9}, {3.9913800927452297`*^9, 3.991380092817713*^9}},
 CellLabel->
  "In[363]:=",ExpressionUUID->"dae1208a-0966-2f4b-bdf1-410e652f2cca"],

