Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{"These", " ", "are", " ", "the", " ", "basic", " ", "scalars"}], 
   "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"\[Phi]0", "[", "exp", "]"}], "=", 
    FractionBox[
     TemplateBox[{"leg1", "leg2"},
      "AAScalar",
      DisplayFunction->(
       RowBox[{"\[LeftAngleBracket]", #, ",", #2, "\[RightAngleBracket]"}]& ),
      InterpretationFunction->(RowBox[{"SHAA", "[", #, ",", #2, "]"}]& )], 
     TemplateBox[{"1"},
      "Mass",
      DisplayFunction->(SubscriptBox["m", #]& ),
      InterpretationFunction->(RowBox[{"m", "[", #, "]"}]& )]]}], ";", 
   RowBox[{
    RowBox[{"\[Phi]t0", "[", "exp", "]"}], "=", 
    FractionBox[
     TemplateBox[{"leg1", "leg2"},
      "BBScalar",
      DisplayFunction->(RowBox[{"[", #, ",", #2, "]"}]& ),
      InterpretationFunction->(RowBox[{"SHBB", "[", #, ",", #2, "]"}]& )], 
     TemplateBox[{"1"},
      "Mass",
      DisplayFunction->(SubscriptBox["m", #]& ),
      InterpretationFunction->(RowBox[{"m", "[", #, "]"}]& )]]}], 
   ";"}]}]], "Input",
