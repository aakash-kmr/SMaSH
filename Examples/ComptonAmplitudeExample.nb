Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{"These", " ", "Scalars", " ", "appear"}], " ", "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{"\[CapitalOmega]0", "[", "exp", "]"}], "[", "S_", "]"}], ":=", 
     RowBox[{
      SuperscriptBox[
       RowBox[{"\[Phi]0", "[", "exp", "]"}], "S"], 
      SuperscriptBox[
       RowBox[{"\[Phi]t0", "[", "exp", "]"}], "S"]}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{"\[CapitalUpsilon]t", "[", "exp", "]"}], "[", "S_", "]"}], ":=",
      " ", 
     RowBox[{"Sum", "[", 
      RowBox[{
       RowBox[{
        FractionBox[
         SuperscriptBox[
          RowBox[{"(", 
           RowBox[{"-", "1"}], ")"}], 
          RowBox[{"S", "-", "b"}]], 
         SuperscriptBox["2", 
          RowBox[{"S", "-", "b"}]]], " ", 
        RowBox[{"Sum", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"Binomial", "[", 
            RowBox[{
             RowBox[{"S", "-", 
              RowBox[{"2", "a"}]}], ",", "b"}], "]"}], 
           RowBox[{"PropCoeff", "[", 
            RowBox[{"S", ",", "a", ",", "4"}], "]"}]}], ",", 
          RowBox[{"{", 
           RowBox[{"a", ",", "0", ",", 
            RowBox[{"Floor", "[", 
             FractionBox[
              RowBox[{"S", "-", "b"}], "2"], "]"}]}], "}"}]}], "]"}], 
        SuperscriptBox[
         RowBox[{"(", 
          RowBox[{
           RowBox[{"\[Phi]14", "[", "exp", "]"}], " ", 
           RowBox[{"\[Phi]23", "[", "exp", "]"}]}], ")"}], 
         RowBox[{"S", "-", "b", "-", "1"}]], 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"\[CapitalOmega]0", "[", "exp", "]"}], "[", "b", "]"}], 
         ")"}]}], ",", 
       RowBox[{"{", 
        RowBox[{"b", ",", "0", ",", 
         RowBox[{"S", "-", "1"}]}], "}"}]}], "]"}]}], ";", 
    RowBox[{
     RowBox[{
      RowBox[{"\[CapitalUpsilon]u", "[", "exp", "]"}], "[", "S_", "]"}], ":=", 
     RowBox[{"Sum", "[", 
      RowBox[{
       RowBox[{
        FractionBox[
         SuperscriptBox[
          RowBox[{"(", 
           RowBox[{"-", "1"}], ")"}], 
          RowBox[{"S", "-", "b"}]], 
         SuperscriptBox["2", 
          RowBox[{"S", "-", "b"}]]], " ", 
        RowBox[{"Sum", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"Binomial", "[", 
            RowBox[{
             RowBox[{"S", "-", 
              RowBox[{"2", "a"}]}], ",", "b"}], "]"}], 
           RowBox[{"PropCoeff", "[", 
            RowBox[{"S", ",", "a", ",", "4"}], "]"}]}], ",", 
          RowBox[{"{", 
           RowBox[{"a", ",", "0", ",", 
            RowBox[{"Floor", "[", 
             FractionBox[
              RowBox[{"S", "-", "b"}], "2"], "]"}]}], "}"}]}], "]"}], 
        SuperscriptBox[
         RowBox[{"(", 
          RowBox[{
           RowBox[{"\[Phi]13", "[", "exp", "]"}], " ", 
           RowBox[{"\[Phi]24", "[", "exp", "]"}]}], ")"}], 
         RowBox[{"S", "-", "b", "-", "1"}]], 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"\[CapitalOmega]0", "[", "exp", "]"}], "[", "b", "]"}], 
         ")"}]}], ",", 
       RowBox[{"{", 
        RowBox[{"b", ",", "0", ",", 
         RowBox[{"S", "-", "1"}]}], "}"}]}], "]"}]}], ";"}]}]}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.963921293271242*^9, 3.963921415108555*^9}, {
  3.9639214606052856`*^9, 3.9639216124279137`*^9}, {3.9639216683859386`*^9, 
