Cell[CellGroupData[{

Cell["Gauge transformation for leg 4", "Section",
 CellChangeTimes->{{3.9913821654933434`*^9, 3.991382168965027*^9}, {
  3.991382507931822*^9, 3.991382511274639*^9}, {3.9913868720145416`*^9, 
  3.9913868732669926`*^9}},ExpressionUUID->"68aa1026-beba-0747-97e2-\
aa3a388254e2"],

Cell[TextData[{
 "The new coefficient ",
 StyleBox["TUCoefficientsGI3",
  FontWeight->"Plain",
  FontSlant->"Italic",
  FontColor->RGBColor[0.8, 0.3, 0.8]],
 " is gauge invariant under leg 3. We now impose gauge transformation under \
leg 4."
}], "Input",
 CellChangeTimes->{{3.99138252710623*^9, 3.991382583993641*^9}, {
  3.991384533392391*^9, 3.991384540571604*^9}},
 FormatType->
  "TextForm",ExpressionUUID->"eaa4e19f-1442-7842-be47-d1d7349711c3"],

Cell[BoxData[
 RowBox[{
  RowBox[{"TUCoefficientsGT4", "[", 
   RowBox[{"h3_", ",", "h4_"}], "]"}], ":=", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"TUCoefficientsGI3", "[", 
          RowBox[{"h3", ",", "h4"}], "]"}], "//", "ToExp"}], "//", 
        "MandelstamtoSH"}], "//", 
       RowBox[{"PureGaugeTransformation", "[", "4", "]"}]}], "//", 
      "ToMandelstam"}], "//", "MandelstamtoSH"}], "//", "Simplify"}], "//", 
   RowBox[{"ReplaceRepeated", "[", 
    RowBox[{
     RowBox[{
      TemplateBox[{"a_", "1", "b_"},
       "ABScalar",
       DisplayFunction->(
        RowBox[{"\[LeftAngleBracket]", #, "\[RightBracketingBar]", #2, 
          "\[LeftBracketingBar]", #3, "]"}]& ),
       InterpretationFunction->(
        RowBox[{"SHAB", "[", #, ",", #2, ",", #3, "]"}]& )], "+", 
      TemplateBox[{"a_", "2", "b_"},
       "ABScalar",
       DisplayFunction->(
        RowBox[{"\[LeftAngleBracket]", #, "\[RightBracketingBar]", #2, 
          "\[LeftBracketingBar]", #3, "]"}]& ),
       InterpretationFunction->(
        RowBox[{"SHAB", "[", #, ",", #2, ",", #3, "]"}]& )]}], ":>", " ", 
     RowBox[{
      RowBox[{"-", 
       TemplateBox[{"a", "3", "b"},
        "ABScalar",
        DisplayFunction->(
         RowBox[{"\[LeftAngleBracket]", #, "\[RightBracketingBar]", #2, 
           "\[LeftBracketingBar]", #3, "]"}]& ),
        InterpretationFunction->(
         RowBox[{"SHAB", "[", #, ",", #2, ",", #3, "]"}]& )]}], "-", 
      TemplateBox[{"a", "4", "b"},
       "ABScalar",
       DisplayFunction->(
        RowBox[{"\[LeftAngleBracket]", #, "\[RightBracketingBar]", #2, 
          "\[LeftBracketingBar]", #3, "]"}]& ),
       InterpretationFunction->(
        RowBox[{"SHAB", "[", #, ",", #2, ",", #3, "]"}]& )]}]}], 
    "]"}]}]}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.9913817857085876`*^9, 3.9913817916420135`*^9}, {
   3.9913818464511204`*^9, 3.9913818508413506`*^9}, 3.991382328499426*^9, {
