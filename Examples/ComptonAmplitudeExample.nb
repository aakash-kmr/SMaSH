04c1ff8e98ff"],

Cell["\<\
The scalars satisfy various important identities which are as follows :\
\>", "Input",
 CellChangeTimes->{{3.9913829832511997`*^9, 3.9913830049918327`*^9}, 
   3.9913844741208534`*^9},
 FormatType->
  "TextForm",ExpressionUUID->"5695fbe6-5c7c-c540-8ed6-3a2eaff73876"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"Identities1", "[", "expr_", "]"}], ":=", 
  RowBox[{
   RowBox[{"expr", "//.", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{
         TemplateBox[{"leg1", "a_"},
          "AAScalar",
          
          DisplayFunction->(
           RowBox[{"\[LeftAngleBracket]", #, ",", #2, 
             "\[RightAngleBracket]"}]& ),
          InterpretationFunction->(RowBox[{"SHAA", "[", #, ",", #2, "]"}]& )], 
         TemplateBox[{"b_", "2", "a_"},
          "ABScalar",
          
          DisplayFunction->(
           RowBox[{"\[LeftAngleBracket]", #, "\[RightBracketingBar]", #2, 
             "\[LeftBracketingBar]", #3, "]"}]& ),
          
          InterpretationFunction->(
           RowBox[{"SHAB", "[", #, ",", #2, ",", #3, "]"}]& )]}], "/;", 
        RowBox[{"a", "=!=", "b"}]}], ":>", 
       RowBox[{
        RowBox[{"-", " ", 
         TemplateBox[{"leg1", "a"},
          "AAScalar",
          
          DisplayFunction->(
           RowBox[{"\[LeftAngleBracket]", #, ",", #2, 
             "\[RightAngleBracket]"}]& ),
          
          InterpretationFunction->(
           RowBox[{"SHAA", "[", #, ",", #2, "]"}]& )]}], 
        TemplateBox[{"b", "1", "a"},
         "ABScalar",
         DisplayFunction->(
          RowBox[{"\[LeftAngleBracket]", #, "\[RightBracketingBar]", #2, 
            "\[LeftBracketingBar]", #3, "]"}]& ),
         InterpretationFunction->(
          RowBox[{"SHAB", "[", #, ",", #2, ",", #3, "]"}]& )]}]}], ",", 
      RowBox[{
       RowBox[{
        RowBox[{
         TemplateBox[{"leg1", "b_"},
