Cell[CellGroupData[{

Cell["Gauge Transformations and contact terms", "Chapter",
 CellChangeTimes->{{3.991380137195677*^9, 3.991380138622654*^9}, {
  3.991380338899111*^9, 3.991380347777096*^9}, {3.9913803834697723`*^9, 
  3.9913803897662373`*^9}, {3.991381869946541*^9, 
  3.991381873434681*^9}},ExpressionUUID->"cdc40945-5f04-814f-aa9b-\
0d83069ced4d"],

Cell[TextData[{
 "The gauge transformations for the each basis coefficient can be evaluated \
separately .  We first apply gauge transformation over leg 3 using ",
 StyleBox["PureGaugeTransformation",
  FontWeight->"Plain",
  FontSlant->"Italic",
  FontColor->RGBColor[0.8, 0.3, 0.8]],
 " and find the corresponding contact terms using ",
 StyleBox["FindContactTerm.",
  FontWeight->"Plain",
  FontSlant->"Italic",
  FontColor->RGBColor[0.8, 0.3, 0.8]],
 " After removing the leg 3 contact terms using ",
 StyleBox["ManifestGI",
  FontWeight->"Plain",
  FontSlant->"Italic",
  FontColor->RGBColor[0.8, 0.3, 0.8]],
 ", the new coefficients depend only on r4 which will be removed usiung the \
same steps."
}], "Input",
 CellChangeTimes->{{3.9913803555932465`*^9, 3.9913803997501583`*^9}, {
  3.991381798596197*^9, 3.9913818340103703`*^9}, {3.991381880227562*^9, 
  3.991382074872381*^9}},
 FormatType->
  "TextForm",ExpressionUUID->"2d94d8d4-4ff2-9742-8007-732f4f1999fc"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"TUCoefficientsGT", "[", 
    RowBox[{"h3_", ",", "h4_"}], "]"}], "[", "leg_", "]"}], ":=", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{"TUCoefficients", "[", 
        RowBox[{"h3", ",", "h4"}], "]"}], "//", "ToExp"}], "//", 
      RowBox[{"PureGaugeTransformation", "[", "leg", "]"}]}], "//", 
     "SHToMandelstam"}], "//", "Simplify"}], "//", 
   RowBox[{"ReplaceRepeated", "[", 
    RowBox[{
     RowBox[{
      TemplateBox[{"a_", "1", "b_"},
       "ABScalar",
       DisplayFunction->(
        RowBox[{"\[LeftAngleBracket]", #, "\[RightBracketingBar]", #2, 
          "\[LeftBracketingBar]", #3, "]"}]& ),
       InterpretationFunction->(
        RowBox[{"SHAB", "[", #, ",", #2, ",", #3, "]"}]& )], "+", 
      TemplateBox[{"a_", "2", "b_"},
       "ABScalar",
       DisplayFunction->(
        RowBox[{"\[LeftAngleBracket]", #, "\[RightBracketingBar]", #2, 
          "\[LeftBracketingBar]", #3, "]"}]& ),
       InterpretationFunction->(
        RowBox[{"SHAB", "[", #, ",", #2, ",", #3, "]"}]& )]}], ":>", " ", 
     RowBox[{
      RowBox[{"-", 
       TemplateBox[{"a", "3", "b"},
        "ABScalar",
        DisplayFunction->(
         RowBox[{"\[LeftAngleBracket]", #, "\[RightBracketingBar]", #2, 
           "\[LeftBracketingBar]", #3, "]"}]& ),
        InterpretationFunction->(
         RowBox[{"SHAB", "[", #, ",", #2, ",", #3, "]"}]& )]}], "-", 
      TemplateBox[{"a", "4", "b"},
       "ABScalar",
       DisplayFunction->(
        RowBox[{"\[LeftAngleBracket]", #, "\[RightBracketingBar]", #2, 
          "\[LeftBracketingBar]", #3, "]"}]& ),
       InterpretationFunction->(
        RowBox[{"SHAB", "[", #, ",", #2, ",", #3, "]"}]& )]}]}], 
    "]"}]}]}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.9913806170023193`*^9, 3.9913806183573513`*^9}, {
  3.9913806526545944`*^9, 3.991380702623892*^9}},
 CellLabel->
  "In[406]:=",ExpressionUUID->"b7da4919-1e63-ed4b-aa4f-414289ed464a"],

